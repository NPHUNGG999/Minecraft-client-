<?xml version="1.0" encoding="utf-8"?>
<!-- File: app/src/main/res/drawable/shape_gradient_button.xml -->
<!-- Mô tả: Shape với gradient từ Tím (#B388FF) sang Cyan (#00E5FF), bo tròn hoàn toàn 2 đầu (Capsule) -->

<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient tuyến tính từ trái sang phải -->
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="@color/gradient_start"
        android:endColor="@color/gradient_end"
        android:gradientRadius="100%p" />

    <!-- Bo tròn hoàn toàn (Capsule) - radius bằng nửa chiều cao button (60dp / 2 = 30dp) -->
    <corners android:radius="30dp" />

    <!-- Shadow/Padding (tùy chọn) -->
    <padding
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp" />

</shape>
